#ifndef SLIM_COMMON_HTTP_RESPONSE_H
#define SLIM_COMMON_HTTP_RESPONSE_H
#include <cstdint>
#include <span>
#include <string>
#include <string_view>
#include <vector>
#include <slim/common/http/headers.h>
#define SLIMCOMMONHTTPRESPONSE_VERSION  "@SLIMCOMMONHTTPRESPONSE_VERSION@"
#define SLIMCOMMONHTTPRESPONSE_GIT_HASH "@SLIMCOMMONHTTPRESPONSE_GIT_HASH@"
namespace slim::common::http {
    struct Response {
            Headers              headers;
            std::string          version;
            std::string          code_text;
            int                  code       = 0;
            std::vector<uint8_t> body;

            Response() = default;
            Response(std::span<uint8_t> buf);

            ErrorStatus parse(std::span<const uint8_t> buf);
            ErrorStatus parse_status_line(std::string_view s, size_t& headers_start);
        };
}
#endif
