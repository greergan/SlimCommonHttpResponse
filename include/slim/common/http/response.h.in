#ifndef SLIM_COMMON_HTTP_RESPONSE_H
#define SLIM_COMMON_HTTP_RESPONSE_H

#include <cstdint>
#include <span>
#include <string>
#include <string_view>

#include <slim/common/http/headers.h>
#include <slim/SlimValue.hpp>

#define SLIMCOMMONHTTPRESPONSE_VERSION  "@SLIMCOMMONHTTPRESPONSE_VERSION@"
#define SLIMCOMMONHTTPRESPONSE_GIT_HASH "@SLIMCOMMONHTTPRESPONSE_GIT_HASH@"

namespace slim::common::http {
    struct Response {
        Response();
        Response(std::span<const uint8_t> storage);

        bool has_error() const;

        slim::slim_storage_container body;
        int                          code         = 0;
        std::string                  code_text;
        std::string                  http_version;
        Headers                      headers;
        slim::ErrorInfo              error_info;

		private:
        	void parse(std::span<const uint8_t> storage);
    };
}

#endif